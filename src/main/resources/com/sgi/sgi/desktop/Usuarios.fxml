<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sgi.sgi.desktop.UsuariosController"
            style="-fx-background-color: #141a0e;">
    <stylesheets>
        <String fx:value="/com/sgi/sgi/desktop/estilo.css"/>
    </stylesheets>

    <top>
        <VBox style="-fx-background-color: #141a0e; -fx-padding: 28 28 14 28;" spacing="14">

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Region prefWidth="4" prefHeight="34"
                        style="-fx-background-color: #a78bfa; -fx-background-radius: 2;"/>
                <VBox spacing="2">
                    <Label text="Usuarios"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #ecf0e5;"/>
                    <Label text="Gestión de cuentas y roles de acceso"
                           style="-fx-font-size: 12px; -fx-text-fill: #586b45;"/>
                </VBox>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="txtBuscar"
                           promptText="🔍  Buscar por nombre, username o rol..."
                           prefWidth="360"
                           onKeyReleased="#buscarUsuario"
                           styleClass="text-field"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="➕  Agregar Usuario" onAction="#abrirFormularioAgregar"
                        style="-fx-background-color: #f5a623; -fx-text-fill: #0a1005;
                               -fx-font-weight: bold; -fx-font-size: 13px;
                               -fx-background-radius: 6; -fx-padding: 10 18 10 18; -fx-cursor: hand;"/>
                <Button text="↺  Actualizar" onAction="#cargarUsuarios"
                        styleClass="btn-secondary"/>
            </HBox>

            <Label fx:id="lblMensaje" text=""
                   style="-fx-font-size: 12px; -fx-text-fill: #10b981;"/>
        </VBox>
    </top>

    <center>
        <VBox style="-fx-padding: 0 28 28 28; -fx-background-color: #141a0e;">
            <TableView fx:id="tablaUsuarios" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colId"       text="#"               prefWidth="50"/>
                    <TableColumn fx:id="colNombre"   text="NOMBRE"          prefWidth="180"/>
                    <TableColumn fx:id="colUsername" text="USERNAME"        prefWidth="140"/>
                    <TableColumn fx:id="colRol"      text="ROL"             prefWidth="110"/>
                    <TableColumn fx:id="colFecha"    text="FECHA CREACIÓN"  prefWidth="160"/>
                    <TableColumn fx:id="colAcciones" text="ACCIONES"        prefWidth="160"/>
                </columns>
                <placeholder>
                    <Label text="👥  No hay usuarios registrados"
                           style="-fx-text-fill: #586b45; -fx-font-size: 14px;"/>
                </placeholder>
            </TableView>
        </VBox>
    </center>

    <right>
        <VBox fx:id="panelFormulario" spacing="12" prefWidth="300" minWidth="300"
              style="-fx-background-color: #0f1409; -fx-padding: 24;
                     -fx-border-color: transparent transparent transparent #2a3820;
                     -fx-border-width: 0 0 0 1;"
              visible="false" managed="false">

            <Label fx:id="lblTituloForm" text="Agregar Usuario"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ecf0e5;"/>

            <Separator styleClass="separator"/>

            <Label text="NOMBRE COMPLETO *" style="-fx-text-fill: #a3b891; -fx-font-size: 10px; -fx-font-weight: bold;"/>
            <TextField fx:id="txtNombre" promptText="Nombre del usuario" styleClass="text-field"/>

            <Label text="USERNAME *" style="-fx-text-fill: #a3b891; -fx-font-size: 10px; -fx-font-weight: bold;"/>
            <TextField fx:id="txtUsername" promptText="Nombre de usuario para login" styleClass="text-field"/>

            <Label text="CONTRASEÑA *" style="-fx-text-fill: #a3b891; -fx-font-size: 10px; -fx-font-weight: bold;"/>
            <PasswordField fx:id="txtPassword" promptText="Contraseña" styleClass="password-field"/>

            <Label text="CONFIRMAR CONTRASEÑA *" style="-fx-text-fill: #a3b891; -fx-font-size: 10px; -fx-font-weight: bold;"/>
            <PasswordField fx:id="txtConfirmarPassword" promptText="Confirmar contraseña" styleClass="password-field"/>

            <Label text="ROL *" style="-fx-text-fill: #a3b891; -fx-font-size: 10px; -fx-font-weight: bold;"/>
            <ComboBox fx:id="cmbRol" maxWidth="Infinity"
                      promptText="Seleccionar rol..."
                      styleClass="combo-box"/>

            <Label fx:id="lblErrorForm" text=""
                   style="-fx-text-fill: #ef4444; -fx-font-size: 12px; -fx-wrap-text: true;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <HBox spacing="8">
                <Button text="💾  Guardar" onAction="#guardarUsuario"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"
                        style="-fx-background-color: #f5a623; -fx-text-fill: #0a1005;
                               -fx-font-weight: bold; -fx-font-size: 13px;
                               -fx-background-radius: 6; -fx-padding: 10; -fx-cursor: hand;"/>
                <Button text="✖" onAction="#cerrarFormulario"
                        style="-fx-background-color: rgba(239,68,68,0.12);
                               -fx-text-fill: #ef4444;
                               -fx-font-size: 14px; -fx-font-weight: bold;
                               -fx-background-radius: 6;
                               -fx-padding: 10 14 10 14; -fx-cursor: hand;
                               -fx-border-color: rgba(239,68,68,0.35); -fx-border-radius: 6;"/>
            </HBox>
        </VBox>
    </right>

</BorderPane>
