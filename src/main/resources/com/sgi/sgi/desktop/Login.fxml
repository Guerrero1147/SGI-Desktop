<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import java.lang.String?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sgi.sgi.desktop.LoginController"
      style="-fx-background-color: #f5f5f4;"
      minWidth="720" minHeight="500"
      prefWidth="720" prefHeight="500">
    <stylesheets>
        <String fx:value="/com/sgi/sgi/desktop/estilo.css"/>
    </stylesheets>

    <!-- ===== PANEL IZQUIERDO — BRANDING ===== -->
    <VBox alignment="CENTER" prefWidth="260" minWidth="260" maxWidth="260"
          style="-fx-background-color: #1c1c1c; -fx-padding: 50 35 50 35;"
          spacing="0">

        <Label text="◈"
               style="-fx-font-size: 52px; -fx-text-fill: #ffffff;"/>

        <Region prefHeight="16"/>

        <Label text="SGI-Desktop"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>

        <Region prefHeight="6"/>

        <Label text="Sistema de Gestión&#10;de Inventarios&#10;(Pequeños negocios-Grandes negocios)"
               style="-fx-font-size: 12px; -fx-text-fill: #9ca3af; -fx-text-alignment: center;"
               textAlignment="CENTER" wrapText="true"/>

        <Region prefHeight="40"/>

        <HBox alignment="CENTER" spacing="8">
            <Region prefWidth="30" prefHeight="1"
                    style="-fx-background-color: rgba(255,255,255,0.15);"/>
            <Label text="v 1.0"
                   style="-fx-text-fill: rgba(255,255,255,0.25); -fx-font-size: 10px;"/>
            <Region prefWidth="30" prefHeight="1"
                    style="-fx-background-color: rgba(255,255,255,0.15);"/>
        </HBox>

        <Region VBox.vgrow="ALWAYS"/>

        <Label text="© 2026 SGI-Desktop"
               style="-fx-text-fill: rgba(255,255,255,0.25); -fx-font-size: 10px;"/>
    </VBox>

    <!-- ===== PANEL DERECHO — FORMULARIO ===== -->
    <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
          style="-fx-padding: 50 55 50 55; -fx-background-color: #ffffff;"
          spacing="0">

        <Label text="Bienvenido de nuevo"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1c1c1c;"/>

        <Region prefHeight="6"/>

        <Label text="Ingresa tus credenciales para continuar"
               style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>

        <Region prefHeight="32"/>

        <!-- Usuario -->
        <Label text="USUARIO"
               style="-fx-text-fill: #6b7280; -fx-font-size: 10px; -fx-font-weight: bold;"/>
        <Region prefHeight="6"/>
        <TextField fx:id="txtUsuario"
                   promptText="Tu nombre de usuario"
                   maxWidth="Infinity"
                   styleClass="text-field"
                   style="-fx-background-color: #ffffff; -fx-text-fill: #1c1c1c;
                          -fx-prompt-text-fill: #9ca3af; -fx-border-color: #e5e5e3;
                          -fx-border-radius: 6; -fx-background-radius: 6;
                          -fx-padding: 10 12 10 12; -fx-font-size: 13px;"/>

        <Region prefHeight="18"/>

        <!-- Contraseña -->
        <Label text="CONTRASEÑA"
               style="-fx-text-fill: #6b7280; -fx-font-size: 10px; -fx-font-weight: bold;"/>
        <Region prefHeight="6"/>
        <PasswordField fx:id="txtPassword"
                       promptText="Tu contraseña"
                       maxWidth="Infinity"
                       style="-fx-background-color: #ffffff; -fx-text-fill: #1c1c1c;
                              -fx-prompt-text-fill: #9ca3af; -fx-border-color: #e5e5e3;
                              -fx-border-radius: 6; -fx-background-radius: 6;
                              -fx-padding: 10 12 10 12; -fx-font-size: 13px;"/>

        <Region prefHeight="10"/>

        <!-- Error -->
        <Label fx:id="lblError" text=""
               maxWidth="Infinity" wrapText="true"
               style="-fx-text-fill: #dc2626; -fx-font-size: 12px; -fx-min-height: 16;"/>

        <Region prefHeight="20"/>

        <!-- Botón -->
        <Button fx:id="btnLogin"
                text="Iniciar Sesión  →"
                maxWidth="Infinity"
                onAction="#handleLogin"
                style="-fx-background-color: #1c1c1c; -fx-text-fill: #ffffff;
                       -fx-font-weight: bold; -fx-font-size: 14px;
                       -fx-background-radius: 6; -fx-padding: 12; -fx-cursor: hand;"/>
    </VBox>

</HBox>
