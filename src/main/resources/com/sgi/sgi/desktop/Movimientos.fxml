<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sgi.sgi.desktop.MovimientosController"
            style="-fx-background-color: #141a0e;">
    <stylesheets>
        <String fx:value="/com/sgi/sgi/desktop/estilo.css"/>
    </stylesheets>

    <top>
        <VBox style="-fx-background-color: #141a0e; -fx-padding: 28 28 14 28;" spacing="14">

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Region prefWidth="4" prefHeight="34"
                        style="-fx-background-color: #10b981; -fx-background-radius: 2;"/>
                <VBox spacing="2">
                    <Label text="Movimientos"
                           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #ecf0e5;"/>
                    <Label text="Entradas, salidas y cortes de caja"
                           style="-fx-font-size: 12px; -fx-text-fill: #586b45;"/>
                </VBox>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <ComboBox fx:id="cmbFiltroTipo" promptText="Todos"
                          styleClass="combo-box"
                          onAction="#filtrarMovimientos"/>

                <TextField fx:id="txtBuscar"
                           promptText="🔍  Buscar por producto u observación..."
                           prefWidth="280"
                           onKeyReleased="#filtrarMovimientos"
                           styleClass="text-field"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="📊  Corte de Caja" onAction="#mostrarCorteDeCaja"
                        styleClass="btn-success"
                        style="-fx-background-color: rgba(16,185,129,0.15); -fx-text-fill: #10b981;
                               -fx-font-size: 13px; -fx-background-radius: 6;
                               -fx-padding: 10 16 10 16; -fx-cursor: hand;
                               -fx-border-color: rgba(16,185,129,0.3); -fx-border-radius: 6;"/>

                <Button text="➕  Nuevo Movimiento" onAction="#abrirFormulario"
                        style="-fx-background-color: #f5a623; -fx-text-fill: #0a1005;
                               -fx-font-weight: bold; -fx-font-size: 13px;
                               -fx-background-radius: 6; -fx-padding: 10 18 10 18; -fx-cursor: hand;"/>

                <Button text="↺  Actualizar" onAction="#cargarMovimientos"
                        styleClass="btn-secondary"/>
            </HBox>

            <Label fx:id="lblMensaje" text=""
                   style="-fx-font-size: 12px; -fx-text-fill: #10b981;"/>
        </VBox>
    </top>

    <!-- TABLA -->
    <center>
        <VBox style="-fx-padding: 0 28 28 28; -fx-background-color: #141a0e;">
            <TableView fx:id="tablaMovimientos" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colFecha"       text="FECHA"         prefWidth="160"/>
                    <TableColumn fx:id="colTipo"        text="TIPO"          prefWidth="90"/>
                    <TableColumn fx:id="colUsuario"     text="USUARIO"       prefWidth="120"/>
                    <TableColumn fx:id="colProductos"   text="TOTAL PRODS."  prefWidth="110"/>
                    <TableColumn fx:id="colValor"       text="VALOR TOTAL"   prefWidth="110"/>
                    <TableColumn fx:id="colObservacion" text="OBSERVACIÓN"   prefWidth="200"/>
                    <TableColumn fx:id="colAcciones"    text="DETALLE"       prefWidth="100"/>
                </columns>
                <placeholder>
                    <Label text="📋  No hay movimientos registrados aún"
                           style="-fx-text-fill: #586b45; -fx-font-size: 14px;"/>
                </placeholder>
            </TableView>
        </VBox>
    </center>

    <!-- FORMULARIO LATERAL -->
    <right>
        <!-- Panel lateral: header fijo + scroll en el cuerpo + footer fijo -->
        <VBox fx:id="panelFormulario" spacing="0" prefWidth="320" minWidth="320"
              style="-fx-background-color: #0f1409;
                     -fx-border-color: transparent transparent transparent #2a3820;
                     -fx-border-width: 0 0 0 1;"
              visible="false" managed="false">

            <!-- ── HEADER fijo ── -->
            <VBox spacing="10" style="-fx-padding: 24 24 12 24;">
                <Label text="Nuevo Movimiento"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ecf0e5;"/>
                <Separator styleClass="separator"/>
            </VBox>

            <!-- ── CUERPO con scroll ── -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        styleClass="panel-scroll"
                        style="-fx-background-color: transparent; -fx-background: #0f1409;
                               -fx-border-color: transparent; -fx-padding: 0;">
                <content>
                    <VBox spacing="10" style="-fx-padding: 0 24 16 24; -fx-background-color: #0f1409;">

                        <Label text="TIPO DE MOVIMIENTO" style="-fx-text-fill: #a3b891; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                        <ComboBox fx:id="cmbTipo" maxWidth="Infinity" styleClass="combo-box"/>

                        <Label text="OBSERVACIÓN" style="-fx-text-fill: #a3b891; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                        <TextField fx:id="txtObservacion" promptText="Ej: Compra a proveedor XYZ"
                                   styleClass="text-field"/>

                        <Separator styleClass="separator"/>

                        <Label text="PRODUCTOS DEL MOVIMIENTO"
                               style="-fx-text-fill: #a3b891; -fx-font-size: 10px; -fx-font-weight: bold;"/>

                        <Label text="PRODUCTO" style="-fx-text-fill: #a3b891; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                        <ComboBox fx:id="cmbProducto" maxWidth="Infinity"
                                  promptText="Seleccionar producto..."
                                  styleClass="combo-box"/>

                        <HBox spacing="10">
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="CANTIDAD" style="-fx-text-fill: #a3b891; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                                <TextField fx:id="txtCantidad" promptText="0" styleClass="text-field"/>
                            </VBox>
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="PRECIO UNITARIO" style="-fx-text-fill: #a3b891; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                                <TextField fx:id="txtPrecioUnitario" promptText="0.00" styleClass="text-field"/>
                            </VBox>
                        </HBox>

                        <Button text="➕  Agregar Producto" onAction="#agregarProductoLista"
                                maxWidth="Infinity"
                                styleClass="btn-secondary"/>

                        <TableView fx:id="tablaDetalle" prefHeight="160" styleClass="table-view">
                            <columns>
                                <TableColumn fx:id="colDetProd"   text="PRODUCTO"  prefWidth="120"/>
                                <TableColumn fx:id="colDetCant"   text="CANT."     prefWidth="50"/>
                                <TableColumn fx:id="colDetPrecio" text="PRECIO"    prefWidth="70"/>
                                <TableColumn fx:id="colDetQuitar" text=""          prefWidth="40"/>
                            </columns>
                            <placeholder>
                                <Label text="Sin productos" style="-fx-text-fill: #586b45;"/>
                            </placeholder>
                        </TableView>

                    </VBox>
                </content>
            </ScrollPane>

            <!-- ── FOOTER fijo: error + botones ── -->
            <VBox spacing="8" style="-fx-padding: 12 24 20 24; -fx-background-color: #0f1409;
                                     -fx-border-color: #2a3820 transparent transparent transparent;
                                     -fx-border-width: 1 0 0 0;">
                <Label fx:id="lblErrorForm" text=""
                       style="-fx-text-fill: #ef4444; -fx-font-size: 12px; -fx-wrap-text: true;"/>
                <HBox spacing="8">
                    <Button text="💾  Guardar" onAction="#guardarMovimiento"
                            HBox.hgrow="ALWAYS" maxWidth="Infinity"
                            style="-fx-background-color: #f5a623; -fx-text-fill: #0a1005;
                                   -fx-font-weight: bold; -fx-font-size: 13px;
                                   -fx-background-radius: 6; -fx-padding: 10; -fx-cursor: hand;"/>
                    <Button text="✖" onAction="#cerrarFormulario"
                            style="-fx-background-color: rgba(239,68,68,0.12);
                                   -fx-text-fill: #ef4444;
                                   -fx-font-size: 14px; -fx-font-weight: bold;
                                   -fx-background-radius: 6;
                                   -fx-padding: 10 14 10 14; -fx-cursor: hand;
                                   -fx-border-color: rgba(239,68,68,0.35); -fx-border-radius: 6;"/>
                </HBox>
            </VBox>

        </VBox>
    </right>

</BorderPane>
